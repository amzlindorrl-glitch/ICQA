        {
            let apiUrl = 'https://adapt-iad.amazon.com/api/employee-profile-svc/GetEmployeeProfiles?employeeLogins=' + JSON.stringify(logins);
            let fun = function(data) {
                employee = data[Object.keys(data)[0]];
                employee.check = function() {
                    if (!(stations.hasOwnProperty(this.login) || stations.hasOwnProperty(this.employeeId)))
                    {
                        if (this.funs.length > 0 )
                        {
                            let fun = this.funs.pop();
                            fun();
                        }
                        else
                        {
                            stations[this.login] = '-';
                            stations[this.employeeId] = '-';
                        };
                    }
                    else
                    {
                        let station = (!!stations[this.login]) ? stations[this.login] : stations[this.employeeId];
                        stations[this.login] = station;
                        stations[this.employeeId] = station;
                        router.showStations();
                    };
                };
                let funer = function(){employee.check()};
                employee.funs = [function(){Robo(funer)},function(){SCC(false,funer)},function(){SCC(true,funer)}]
                employee.check();
            };
            apiGetCall(apiUrl, fun);
        };
        function apiGetCall(url, code)
        {
            GM_xmlhttpRequest({
                method: 'GET',
                url: url,
                onload: function (response) {
                    let data = response.responseText;
                    data = ( typeof data === 'object' ) ? data : JSON.parse(data);
                    if (!!code)
                    {
                        code(data)
                    };
                }
            });
        };
        function SCC(process,code)
        {
            var planId;
            let funInception = function (data){
                let obj = data.employeeIdToStationsMap
                let keys = Object.keys(obj);
                for( let i = 0; i < keys.length; i++ )
                {
                    stations[keys[i]] = obj[keys[i]][0].scannableId;
                };
                code();
            };
            let funInside = function(data, process){
                let obj;
                let nearestTime = 0 ;
                var nower = new Date();
                for( let i =0; i < data.length; i++ )
                {
                    if ( data[i].startTime*1000 > nearestTime && nower > data[i].startTime*1000 )
                    {
                        obj = data[i];
                        nearestTime = data[i].startTime;
                    };
                };
                apiPostCall('https://staffingcommandcenter-' + c + '.aka.amazon.com/getStaffingPlansForWorkInterval/' + planId + '/' + process, obj, funInception, process);
            };
            let fun = function(data, process){
                planId = data.planId;
                apiGetCall('https://staffingcommandcenter-' + c + '.aka.amazon.com/getPlanIntervals/' + data.planId + '/' + building + '/' + process, funInside, process);
            };

            if (process)
