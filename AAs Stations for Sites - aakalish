                    let rows = $('table[role="table"]').children('tbody').children('tr');

                    for ( let i = 0; i < rows.length; i++ )
                    {
                        let row = rows[i];
                        let newTd = $( row ).children('td.station')[0];
                        newTd.innerText = stations.hasOwnProperty(row.children[1].innerText) ? stations[row.children[1].innerText] : '-';
                    };
                };
            };
        }
        , filledElement: null
        , numberOfRows: 0
    };

