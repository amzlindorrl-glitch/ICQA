                header.insertBefore(newTd, header.children[3])
            };
            if ($('table[role="table"]').children('tbody').children('tr')[0].children.length > 1 )
            {
                if ($('td.station').length == 0)
                {
                    let rows = $('table[role="table"]').children('tbody').children('tr');

                    for ( let i = 0; i < rows.length; i++ )
                    {
                        let row = rows[i];
                        let newTd = row.children[2].cloneNode(true);
