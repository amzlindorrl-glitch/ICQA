    var getBuilding = function(url) {
        if ( url.split('pick-workforce').length > 1)
        {
            return url.split('fc/')[1].split('/')[0];
        }
        else if ( url.split('action_center').length > 1 )
        {
            return url.split('/')[5];
        }
        else if ( url.split('atlas').length > 1 )
        {
            return url.split('warehouseId=')[1].split('&')[0];
        }
        else if( url.split('workingwell').length > 1 )
        {
            return url.split('site=')[1].split('&')[0];
        }
        else if ( url.split('hrr.corp.amazon.com').length > 1 )
        {
            return $('select')[0].value ;
        }
        else if ( url.split('afttrans').length > 1 || url.split('speed').length > 1 )
        {
            return document.URL.split('/')[3] ;
        }
        else if ( url.split('mastermind').length > 1 )
        {
            return $('#fc')[0].value ;
        }
        else if ( url.split('quicksight').length > 1 )
        {
            wait = false;
            observer = new MutationObserver(function(mutations){
                observer.disconnect();
                if ($('[title="FC"]').length > 0 )
                {
                    wait = true;
                    building = $('[title="FC"]')[0].nextElementSibling.innerText;
                    router.start();
                }
                else
                {
                    observer.observe(document.documentElement, {
                        childList: true,
                        subtree: true
                    });
                };
            });
            observer.observe(document.documentElement, {
                childList: true,
                subtree: true
            });
        }
        else
        {
            return url.split('warehouseId=')[1].split('&')[0];
        };
    };
    var building = getBuilding(document.URL);

    var functionRollup = {
        start : function()
        {
            getStations();
        }
        , show : function()
        {
            var tbls = document.getElementsByClassName('sortable result-table align-left');
            for ( var i = 0; i < tbls.length; i++ )
            {
                if (tbls[i].querySelectorAll('.headComplete').length == 0)
                {
                    let thead = tbls[i].querySelector('thead');
                    let hd = thead.children[0].children[0].cloneNode(true);
                    hd.innerText = 'Station';
                    hd.classList.add('headComplete');
                    thead.children[0].insertBefore(hd,thead.children[0].children[4]);
                    $(hd).click(function() {
                        let down = true;
                        if(this.classList.contains('headerSortDown'))
                        {
                            down = false;
                        }
                        this.className = this.className.replace('headerSortUp','').replace('headerSortDown','');
                        this.className += down? ' headerSortDown' : ' headerSortUp';
                        let col = 0;
                        let column = 0;
                        let ch = this.parentElement.children
                        let cur = this;
                        while (col < ch.length)
                        {
                            if(cur.previousSibling.hasOwnProperty('column'))
                            {
                                column = cur.previousSibling.column + col;
                                col = ch.length
                            }
                            else
                            {
                                cur = cur.previousSibling
                            };
                            col++;
                        };
                        let table = $(this).closest('table').find('tbody')[0];
                        let rows = $(this).closest('table').find('tbody').find('tr[class*=empl]');
                        rows.sort(function(a,b) { if( a.children[column].innerText > b.children[column].innerText ) { return (down? -1 : 1) * 1; } else { return (down? -1 : 1) * -1; }})
                        rows.each(function() { table.appendChild(this) });
                    });
                };
                let rows = tbls[i].querySelectorAll('tr.empl-all');
                for ( var j = 0; j < rows.length-1; j++ )
                {
                    if(rows[j].querySelectorAll('#id' + rows[j].children[1].innerText).length == 0)
                    {
                        let td = rows[j].children[0].cloneNode(true);
                        td.innerText = stations.hasOwnProperty(rows[j].children[1].innerText) ? stations[rows[j].children[1].innerText] : '-';
                        td.id = 'id' + rows[j].children[1].innerText;
                        rows[j].insertBefore(td,rows[j].children[4]);
                    }
                    else if(rows[j].querySelectorAll('#id' + rows[j].children[1].innerText).length == 1)
                    {
                        rows[j].querySelectorAll('#id' + rows[j].children[1].innerText)[0].innerText = stations.hasOwnProperty(rows[j].children[1].innerText) ? stations[rows[j].children[1].innerText] : '-';
                    };
                };
                if (!rows[rows.length-1].children[0].classList.contains('here'))
                {
                    rows[rows.length-1].children[0].colSpan = rows[rows.length-1].children[0].colSpan + 1;
                    rows[rows.length-1].children[0].classList.add('here');
                };
            };
        }
    };

