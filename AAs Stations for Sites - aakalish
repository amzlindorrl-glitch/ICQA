        function Robo(code)
        {
            getStationsFromApi(code);


            function getStationsFromApi(fun)
            {
                var apiUrls = [
                    'https://roboscout.amazon.com/view_plot_data/?sites=(' + building + ')&instance_id=2078&object_id=20672&BrowserTZ=America%2FNew_York&app_name=RoboScout',
                    'https://roboscout.amazon.com/view_plot_data/?sites=(' + building + ')&instance_id=2080&object_id=20672&BrowserTZ=America%2FNew_York&app_name=RoboScout',
                    'https://roboscout.amazon.com/view_plot_data/?sites=(' + building + ')&instance_id=2081&object_id=20672&BrowserTZ=America%2FNew_York&app_name=RoboScout',
                    'https://roboscout.amazon.com/view_plot_data/?sites=(' + building + ')&instance_id=2079&object_id=20672&BrowserTZ=America%2FNew_York&app_name=RoboScout'
                ];

                for ( let i = 0; i < apiUrls.length; i++ )
                {
                    callApi(apiUrls[i], function(data,url) { makeObjWithStations(data,url); fun();});
                };
            };

            function callApi(url,code)
            {
                GM_xmlhttpRequest({
                    method: "GET",
                    url: url,
                    onload: function (response) {
                        let data = response.responseText;
                        data = ( typeof data === 'object' ) ? data : JSON.parse(data);
                        if (!!code)
                        {
                            code(data,url)
                        };
                    }
                });
            };

            function makeObjWithStations(data,key)
            {
                let temp = {};
                for ( let i = 0; i < data.data.length; i++ )
                {
                    if(data.data[i].key == 'Station_Id' || data.data[i].key == 'Associate Login')
                    {
                        checkThenAdd(temp,data.data[i].xValue, data.data[i].key, data.data[i].yValue);
                    };
                };
                let keys = Object.keys(temp);
                for ( let i = 0; i < keys.length; i++ )
                {
                    let obj = temp[keys[i]];
                    stations[obj["Associate Login"]] = obj["Station_Id"];
                };
            };
            function checkThenAdd(obj, objKey, key, value)
            {
                value = (value.split('>').length > 1) ? value.split('>')[1].split('<')[0] : value;
                if (obj.hasOwnProperty(objKey))
                {
                    obj[objKey][key] = value;
                }
                else
                {
                    obj[objKey] = {};
                    obj[objKey][key] = value;
                };
            };
        };


    };
