                getStarted('PPAFE2');
            };

            function getStarted(process)
            {
                apiGetCall('https://staffingcommandcenter-' + c + '.aka.amazon.com/getLatestGeneratedPlanRecord/' + building, fun, process);
            };

            function apiGetCall(url, code, process)
            {
                GM_xmlhttpRequest({
                    method: 'GET',
                    url: url,
                    onload: function (response) {
                        let data = response.responseText;
